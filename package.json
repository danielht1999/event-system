{
  "name": "event-system",
  "version": "1.0.0",
  "description": "Sistema de gestión de eventos y reservas",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node -r tsconfig-paths/register src/server.ts",
    "dev:load-test": "npm run dev -- --isLoadTest",
    "dev:client": "npm run dev --prefix client",

    "build": "tsc",
    "start": "node dist/server.js",

    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage --runInBand",

    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "infra:restart": "docker compose restart",
    "infra:logs": "docker compose logs -f",
    "infra:ps": "docker compose ps",

    "db:migrate": "ts-node src/shared/infrastructure/database/migrate.ts",
    "db:reset": "ts-node src/shared/infrastructure/database/reset-and-migrate.ts",
    "db:seed": "ts-node src/shared/infrastructure/database/seed.ts",

    "load:events": "k6 run tests/load/events.load.js",
    "load:reservations": "k6 run tests/load/reservations.load.js",
    "load:mix": "k6 run tests/load/mix.load.js"
  },
  "dependencies": {
    "amqplib": "^0.10.3",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.6",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-rate-limit": "^6.11.2",
    "helmet": "^7.2.0",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.0",
    "morgan": "^1.10.1",
    "node-cron": "^4.2.1",
    "nodemailer": "^6.9.3",
    "pg": "^8.20.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.3",
    "redis": "^4.6.7",
    "uuid": "^9.0.1",
    "winston": "^3.9.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.25",
    "@types/jest": "^29.5.14",
    "@types/joi": "^17.2.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.39",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "eslint": "^8.43.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "prettier": "^2.8.8",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3"
  }
}